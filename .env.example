# Supabase konfigurace
# Tyto hodnoty získáte z Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email API
# Získejte na https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Admin účet pro Supabase Auth
# Tento email použijte pro vytvoření admin účtu v Supabase
ADMIN_EMAIL=admin@vedcizjistili.cz

# Netlify konfigurace
# Pro lokální vývoj nastavte na http://localhost:8000
SITE_URL=https://vedcizjistili.cz
